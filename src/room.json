  { "id": 2004, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E6%A5%B5%E5%8C%97%E5%B4%A9%E8%A3%82%E5%86%B0%E5%8E%9F.png?alt=media&token=50d80c68-4146-4118-893e-3d7025898b72", "theme": "Disaster", "name": "極北崩裂冰原", "door_visual": "覆蓋霜雪的木門，把手凍結，門後有暴風雪嘯聲。", "env_features": "零下 50 度的極低溫，能見度不到一公尺。", "hp_change": -4, "resource_desc": null, "threat_desc": "失溫症威脅、雪地裂縫，以及伺機而動的雪狼。" },
  { "id": 2005, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E5%A0%B1%E5%BB%A2%E8%BB%8A%E8%BC%9B%E5%A3%93%E7%B8%AE%E5%B7%A5%E5%BB%A0.png?alt=media&token=19044f75-7df8-454e-86b4-d54f5dd9585a", "theme": "Industrial", "name": "報廢車輛壓縮工廠", "door_visual": "油汙金屬捲簾門，內部有液壓機運作與金屬撕裂聲。", "env_features": "充滿廢氣味，地面滿是尖銳的金屬碎片。", "hp_change": -3, "resource_desc": null, "threat_desc": "定時啟動的空間壓縮牆、四處噴濺的火花。" },
  { "id": 2006, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E7%84%A1%E9%99%90%E5%BE%AA%E7%92%B0%E7%9A%84%E7%B4%85%E7%87%88%E5%8D%80.png?alt=media&token=978a46ab-34ec-437c-bd45-999334a184c5", "theme": "Supernatural", "name": "無限循環的紅燈區", "door_visual": "老舊紅色木門，閃爍不定的燈牌，門後有嬌笑聲。", "env_features": "無論往哪走都會回到原點，強烈紅光讓人目眩。", "hp_change": -4, "resource_desc": null, "threat_desc": "潛伏暗巷中的無臉魅影，以及誘使踏入陷阱的幻聽。" },
  { "id": 2007, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E5%A4%B1%E8%90%BD%E7%8E%8B%E6%9C%9D%E7%9A%84%E9%BB%91%E6%9A%97%E5%8F%A4%E5%A2%93.png?alt=media&token=65c4a252-8ab7-4882-9d02-8d6db8821830", "theme": "Ancient", "name": "失落王朝的黑暗古墓", "door_visual": "布滿青苔石門，門縫中飄出陳腐的泥土味。", "env_features": "幾乎無光，只能靠微弱火把照明；沉重空氣壓得人難以呼吸。", "hp_change": -5, "resource_desc": null, "threat_desc": "流沙陷阱、劇毒連弩，以及守護陵墓的木乃伊。" },
  { "id": 2008, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E5%A3%95%E6%BA%9D%E6%88%B0%E7%81%AB%E5%89%8D%E7%B7%9A.png?alt=media&token=016da71c-e722-4ab4-b8b7-e38f673dae49", "theme": "War", "name": "壕溝戰火前線", "door_visual": "布滿彈孔的鐵門，外掛防毒面具，有連綿砲擊聲。", "env_features": "空氣充斥火藥味，地面泥濘，天空呈現焦橘色。", "hp_change": -4, "resource_desc": null, "threat_desc": "隨機落下的砲彈、地雷，以及致命的毒氣雲。" },
  { "id": 2009, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E6%B5%81%E6%B2%99%E7%83%88%E6%97%A5%E8%8D%92%E6%BC%A0.png?alt=media&token=de14c377-8dcc-457a-a637-35559b6b6566", "theme": "Desert", "name": "流沙烈日荒漠", "door_visual": "風化砂岩門，門板滾燙，推開時有細砂湧出。", "env_features": "氣溫 55 度，強烈紫外線直射，地表頻繁流沙。", "hp_change": -3, "resource_desc": null, "threat_desc": "缺水導致的幻覺、砂層下的劇毒蠍群。" },
  { "id": 2010, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E5%8D%8A%E5%A4%9C%E7%9A%84%E5%BB%A2%E6%A3%84%E9%86%AB%E9%99%A2.png?alt=media&token=c0079e6c-faae-46d1-b1fb-dffac975e24a", "theme": "Ghost", "name": "半夜的廢棄醫院", "door_visual": "毛玻璃門上有鮮紅手印，後方有擔架滑過影。", "env_features": "燈光閃爍，氣溫極低，耳邊有不明嘆息聲。", "hp_change": -4, "resource_desc": null, "threat_desc": "手術室徘徊的怨靈、突然倒下的置物架。" },
  { "id": 2011, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E8%87%AA%E5%8B%95%E6%8B%86%E8%A7%A3%E6%B5%81%E6%B0%B4%E7%B7%9A.png?alt=media&token=61355d6c-0fa1-40e7-b027-20d5a7f6d049", "theme": "Mechanical", "name": "自動拆解流水線", "door_visual": "不鏽鋼門，警告標語「危險！自動化作業中」。", "env_features": "地面是移動傳送帶，重力頻繁改變方向。", "hp_change": -5, "resource_desc": null, "threat_desc": "高速旋轉的切割鋸片、強力磁鐵，以及從天而降的重錘。" },
  { "id": 2012, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E7%A0%B4%E7%A2%8E%E7%9A%84%E8%99%9B%E7%A9%BA%E6%96%B7%E5%B1%A4.png?alt=media&token=f9c0ac7e-9743-4975-bcfc-3012a29fb797", "theme": "Void", "name": "破碎的虛空斷層", "door_visual": "不存在實體的門，只是一團扭曲的空間黑影。", "env_features": "沒有地面，須在碎石間跳躍，氧氣稀薄。", "hp_change": -5, "resource_desc": null, "threat_desc": "掉入無底深淵的恐懼、空間扭曲的撕裂力。" },
  { "id": 2013, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E5%B7%A8%E5%9E%8B%E6%98%86%E8%9F%B2%E7%9A%84%E5%B7%A2%E7%A9%B4.png?alt=media&token=8fbd3188-f97d-4eb7-8d5a-db8d0b025c56", "theme": "Insects", "name": "巨型昆蟲的巢穴", "door_visual": "布滿黏稠蛛網，縫隙看見無數對發光的複眼。", "env_features": "空氣悶熱潮濕，腳下是滑膩黏液，牆上掛滿繭。", "hp_change": -4, "resource_desc": null, "threat_desc": "天花板的巨大毒蛛、強腐蝕性的蟻酸噴射。" },
  { "id": 2014, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E6%B7%B1%E6%B7%B5%E9%BB%91%E6%B4%9E%E9%82%8A%E7%B7%A3.png?alt=media&token=31401d88-46c0-48c0-b11b-61ad79add265", "theme": "Abyss", "name": "深淵黑洞邊緣", "door_visual": "正在被吸進去變形的門，門後一片漆黑。", "env_features": "時間感扭曲，極大的潮汐力撕扯著肉體。", "hp_change": -6, "resource_desc": null, "threat_desc": "奇點的吸引力、被光速碎片擊中的風險。" },
  { "id": 2015, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E6%B0%B8%E6%81%86%E5%88%91%E8%A8%8A%E5%AE%A4.png?alt=media&token=a955af7c-60a0-4f02-932c-8ab4fd125953", "theme": "Prison", "name": "永恆刑訊室", "door_visual": "厚重的生鏽鐵門，傳來鞭打聲與慘叫聲。", "env_features": "地板沾滿乾涸血跡，空氣中充滿鐵鏽味。", "hp_change": -4, "resource_desc": null, "threat_desc": "自動揮舞的鎖鏈、地面突然冒出的尖刺。" },
  { "id": 2016, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E9%AB%98%E5%A3%93%E9%9B%BB%E7%BA%9C%E5%9E%83%E5%9C%BE%E5%A0%B4.png?alt=media&token=2ef04e77-480f-46fb-b2e3-1ce2e2f75082", "theme": "Cyberpunk", "name": "高壓電纜垃圾場", "door_visual": "外露電線的鐵門，不斷發出劈啪的跳火聲。", "env_features": "地面滿是強鹼化學池，空氣中充滿臭氧味。", "hp_change": -3, "resource_desc": null, "threat_desc": "斷裂的萬伏電纜、失控的清潔無人機。" },
  { "id": 2017, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E7%97%85%E6%AF%92%E5%9F%B9%E9%A4%8A%E5%AF%A6%E9%A9%97%E5%AE%A4.png?alt=media&token=185f60b7-8f95-462d-a7ff-e5b81efe60a9", "theme": "Biological", "name": "病毒培養實驗室", "door_visual": "門上長滿綠色孢子，門縫滲出黏稠黃液。", "env_features": "呼吸會感到肺部灼燒，牆壁在滲透酸液。", "hp_change": -5, "resource_desc": null, "threat_desc": "變異的真菌孢子、不斷噴射毒霧的肉瘤。" },
  { "id": 2018, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E7%86%94%E5%B2%A9%E5%99%B4%E7%99%BC%E9%9A%A7%E9%81%93.png?alt=media&token=abcce7cb-35f1-4c86-b5fc-525a6e94eaf0", "theme": "Volcano", "name": "熔岩噴發隧道", "door_visual": "燒得通紅的岩石門，門把手已經熔化。", "env_features": "地面隨時會裂開湧出岩漿，空氣含硫量極高。", "hp_change": -5, "resource_desc": null, "threat_desc": "噴發的火山灰、流動的岩漿河、極高溫。" },
  { "id": 2019, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E8%85%90%E8%9D%95%E6%80%A7%E5%BC%B7%E9%85%B8%E9%9B%A8%E6%9E%97.png?alt=media&token=da435601-e391-4d59-96a4-fa928dd76173", "theme": "Acid", "name": "腐蝕性強酸雨林", "door_visual": "植物在門板上迅速枯萎又生長的詭異門。", "env_features": "天降強酸雨，所有遮蔽物都在緩慢熔化。", "hp_change": -4, "resource_desc": null, "threat_desc": "腐蝕性雨滴、會噴灑溶血毒素的奇異植物。" },
  { "id": 2020, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E7%A0%B4%E7%A2%8E%E7%9A%84%E9%8F%A1%E5%83%8F%E8%BF%B7%E5%AE%AE.png?alt=media&token=c2c6ac2f-c6da-4dc1-9fe7-3f255edfa86e", "theme": "Mirage", "name": "破碎的鏡像迷宮", "door_visual": "門本身就是一面鏡子，映照出你慘死的樣子。", "env_features": "視線被無數反射干擾，分不清哪裡是路。", "hp_change": -3, "resource_desc": null, "threat_desc": "鏡中走出的敵對幻影、銳利的玻璃碎片。" },
  { "id": 2021, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E8%B6%85%E9%9F%B3%E6%B3%A2%E5%85%B1%E6%8C%AF%E5%AE%A4.png?alt=media&token=99736ce7-f255-443d-a5d4-c611c3f2153f", "theme": "Sound", "name": "超音波共振室", "door_visual": "蜂窩結構的門，傳來足以震碎玻璃的低音。", "env_features": "身體器官隨著頻率震動，產生強烈噁心感。", "hp_change": -4, "resource_desc": null, "threat_desc": "超高分貝衝擊波導致的內耳出血與內傷。" },
  { "id": 2022, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E5%BB%A2%E6%A3%84%E5%B1%A0%E5%AE%B0%E5%BB%9A%E6%88%BF.png?alt=media&token=0987504a-a525-48de-a0ef-3adfb19c742b", "theme": "Kitchen", "name": "廢棄屠宰廚房", "door_visual": "掛著巨大砍刀的門，門縫滴下深紅色液體。", "env_features": "滿地都是殘骸，巨大肉鉤在天花板滑動。", "hp_change": -4, "resource_desc": null, "threat_desc": "自動切割機、揮舞菜刀的瘋狂主廚影。" },
  { "id": 2023, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E5%A4%B1%E6%8E%A7%E9%87%8D%E5%8A%9B%E5%AE%A4.png?alt=media&token=bf707490-3e7f-48fd-b329-e777ec41b2c0", "theme": "Gravity", "name": "失控重力室", "door_visual": "門板在重力作用下上下劇烈晃動的合金門。", "env_features": "重力方向每三秒隨機切換一次，極易骨折。", "hp_change": -5, "resource_desc": null, "threat_desc": "被拋飛撞擊牆壁、內臟因重力頻閃受損。" },
  { "id": 2024, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E9%9B%B7%E9%9B%B2%E9%AB%98%E5%A3%93%E5%A1%94.png?alt=media&token=560f9de3-45dc-4145-ab99-7026b664b98b", "theme": "Electric", "name": "雷雲高壓塔", "door_visual": "避雷針造型的門，門把手不斷閃爍電火花。", "env_features": "地面是絕緣體，但空氣中布滿靜電與閃電。", "hp_change": -5, "resource_desc": null, "threat_desc": "定時落下的球狀閃電、空氣擊穿後的焦灼。" },
  { "id": 2025, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E7%84%A1%E5%85%89%E5%90%9E%E5%99%AC%E4%B9%8B%E5%A2%83.png?alt=media&token=8b43b57e-026e-439d-a797-99d99da9bc19", "theme": "Darkness", "name": "無光吞噬之境", "door_visual": "吸盡所有光線的門，連你的影子都會消失。", "env_features": "絕對黑暗，感官全部失效，只有冰冷觸感。", "hp_change": -4, "resource_desc": null, "threat_desc": "潛藏在黑暗中撕咬肉體的未知影獸。" },
  { "id": 2026, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E6%81%90%E6%80%96%E7%8E%A9%E5%81%B6%E5%B7%A5%E5%BB%A0.png?alt=media&token=de43acff-03db-4d8d-bc37-9bb06765beb3", "theme": "Toy", "name": "恐怖玩偶工廠", "door_visual": "門把是一個壞掉的小丑頭像，發出怪笑。", "env_features": "堆滿殘缺的布偶，空氣中充滿劣質棉花味。", "hp_change": -3, "resource_desc": null, "threat_desc": "會背後襲擊的小丑玩偶、噴射尖釘的機關。" },
  { "id": 2027, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E6%B4%BB%E9%AB%94%E6%B6%88%E5%8C%96%E9%81%93.png?alt=media&token=6fa081dc-9d0f-4203-8aba-75dae0098303", "theme": "Flesh", "name": "活體消化道", "door_visual": "像嘴巴一樣會開合的門，黏液濕滑。", "env_features": "地面在強烈蠕動，不斷分泌強效消化液。", "hp_change": -5, "resource_desc": null, "threat_desc": "腐蝕性胃酸池、緊縮的肌肉瓣膜壓力。" },
  { "id": 2028, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E5%8A%87%E6%AF%92%E5%BB%A2%E6%B0%B4%E4%B8%8B%E6%B0%B4%E9%81%93.png?alt=media&token=9ae3ce9c-05a9-4e2b-8497-46003f3e038d", "theme": "Sewer", "name": "劇毒廢水下水道", "door_visual": "生鏽的圓形井蓋門，散發惡臭與沼氣。", "env_features": "水位沒過膝蓋，水中含有致命的重金屬。", "hp_change": -4, "resource_desc": null, "threat_desc": "水底的尖銳鋼筋、具有攻擊性的變異鼠群。" },
  { "id": 2029, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E7%84%A1%E9%99%90%E7%99%BC%E6%A2%9D%E8%BF%B7%E5%AE%AE.png?alt=media&token=eb7b00d3-8364-43a4-90ed-367d7ee6c01c", "theme": "Clockwork", "name": "無限發條迷宮", "door_visual": "布滿旋轉齒輪的銅門，轉動時咔咔作響。", "env_features": "牆壁與地板不斷變換位置，極易被擠壓。", "hp_change": -4, "resource_desc": null, "threat_desc": "巨大的咬合齒輪、彈出的發條尖刺。" },
  { "id": 2030, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E6%A0%B8%E5%BB%A2%E6%96%99%E5%84%B2%E5%AD%98%E6%A7%BD.png?alt=media&token=95d7f8ee-c1c0-4196-ba11-d4edb6d41ea6", "theme": "Radiation", "name": "核廢料儲存槽", "door_visual": "亮黃色門標示著輻射警告，門板發燙。", "env_features": "視線出現雜訊，空氣中有強烈的電離味。", "hp_change": -6, "resource_desc": null, "threat_desc": "急性的組織壞死、不可見的輻射射線。" },
  { "id": 2031, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E6%B4%BB%E5%9F%8B%E6%A3%BA%E6%9D%90%E9%96%93.png?alt=media&token=8e5bf000-73eb-453e-a7ef-f613a39a01c1", "theme": "Underground", "name": "活埋棺材間", "door_visual": "狹窄低矮的木門，像是一口豎立的棺材。", "env_features": "空間極度狹小，氧氣即將耗盡，壓力巨大。", "hp_change": -4, "resource_desc": null, "threat_desc": "幽閉恐懼導致的崩潰、緩慢崩塌的泥土。" },
  { "id": 2032, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E8%A1%80%E8%89%B2%E9%A6%AC%E6%88%B2%E5%9C%98%E5%B8%B3%E7%AF%B7.png?alt=media&token=808f9e09-a729-481e-907f-f749921834b2", "theme": "Carnival", "name": "血色馬戲團帳篷", "door_visual": "紅白條紋的布門，門後傳來瘋狂的音樂。", "env_features": "五顏六色的煙霧帶有神經毒素，使人發狂。", "hp_change": -4, "resource_desc": null, "threat_desc": "拿著電鋸的雜耍者影子、噴火的機械獅。" },
  { "id": 2033, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E6%B0%B8%E6%81%86%E5%8A%A0%E7%8F%AD%E5%9C%B0%E7%8D%84.png?alt=media&token=d4b2923a-227a-420a-95de-9fa5be8a1ac1", "theme": "Office", "name": "永恆加班地獄", "door_visual": "普通的灰色辦公門，傳來無盡的打字聲。", "env_features": "日光燈頻率讓人焦躁，空氣渾濁且枯燥。", "hp_change": -3, "resource_desc": null, "threat_desc": "精神枯竭引發的體力衰退、自動化的文書陷阱。" },
  { "id": 2034, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E7%8B%82%E6%9A%B4%E9%9B%B7%E9%9B%A8%E6%B5%B7%E9%9D%A2.png?alt=media&token=73c974c3-c76b-4153-82d8-9e505de5f722", "theme": "Sea", "name": "狂暴雷雨海面", "door_visual": "濕透的帆布門，門後傳來驚濤駭浪聲。", "env_features": "腳下是不穩的木板，隨時被冰冷海水吞沒。", "hp_change": -4, "resource_desc": null, "threat_desc": "低溫海水的失溫、海中巨大的掠食者影。" },
  { "id": 2035, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E5%86%B0%E9%9C%9C%E5%B7%A8%E4%BA%BA%E9%A0%98%E5%9C%B0.png?alt=media&token=036603e3-45e4-4a61-a1d0-6841bb0f46ff", "theme": "Viking", "name": "冰霜巨人領地", "door_visual": "鑲嵌著寒冰碎片的石門，門把手凍黏皮膚。", "env_features": "重力是正常三倍，空氣冰冷如刀，視野模糊。", "hp_change": -5, "resource_desc": null, "threat_desc": "隨機掉落的巨型冰柱、狂暴的極寒氣流。" },
  { "id": 2036, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E5%AF%84%E7%94%9F%E7%9C%9F%E8%8F%8C%E6%BA%AB%E5%AE%A4.png?alt=media&token=e9e7a99e-a312-4edf-9663-2f64c7366c78", "theme": "Parasite", "name": "寄生真菌溫室", "door_visual": "布滿黃色斑點的門，不斷噴出細小的粉末。", "env_features": "地面滿是柔軟的菌絲，空氣甜膩得令人窒息。", "hp_change": -4, "resource_desc": null, "threat_desc": "鑽入皮膚的寄生真菌、炸裂噴灑孢子的肉球。" },
  { "id": 2037, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E5%A4%B1%E5%A3%93%E7%9A%84%E5%A4%AA%E7%A9%BA%E5%BB%8A%E9%81%93.png?alt=media&token=e1c7bc0e-a922-497d-9f1a-17222b66c837", "theme": "Space", "name": "失壓的太空廊道", "door_visual": "碎裂的強化玻璃門，隱約見到外面的真空。", "env_features": "氧氣面罩破損，耳鳴嚴重，環境極度寒冷。", "hp_change": -5, "resource_desc": null, "threat_desc": "快速流失的氣壓、飛散的銳利金屬碎片。" },
  { "id": 2038, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E7%99%BE%E9%AC%BC%E5%A4%9C%E8%A1%8C%E7%9A%84%E7%AA%84%E5%B7%B7.png?alt=media&token=7f1efb43-497f-44dd-83bc-91747e3ba807", "theme": "Japanese", "name": "百鬼夜行的窄巷", "door_visual": "破舊的提燈木門，傳來木屐敲擊地面的聲音。", "env_features": "巷子無限延伸，兩側充滿惡意的窺視感。", "hp_change": -4, "resource_desc": null, "threat_desc": "突然襲來的妖怪爪影、永遠走不出的鬼打牆。" },
  { "id": 2039, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E6%95%85%E9%9A%9C%E7%9A%84%E9%BB%98%E7%89%87%E5%8A%87%E9%99%A2.png?alt=media&token=773286f5-5092-4cdd-9049-fa05c0dd596b", "theme": "Cinema", "name": "故障的默片劇院", "door_visual": "深紅色天鵝絨門，散發一股膠捲燒焦味。", "env_features": "只有黑白色彩，且動作會有延遲與掉幀感。", "hp_change": -3, "resource_desc": null, "threat_desc": "銀幕中伸出的手、不斷縮小的觀眾席位。" },
  { "id": 2040, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E4%B8%8D%E7%A9%A9%E5%AE%9A%E7%93%A6%E6%96%AF%E7%A4%A6%E5%9D%91.png?alt=media&token=37765ed5-f143-4718-89b6-5241000b86f3", "theme": "Mine", "name": "不穩定瓦斯礦坑", "door_visual": "漆黑的坑道入口門，有礦燈不斷閃爍。", "env_features": "空氣極薄且易燃，腳下隨時會塌陷，極熱。", "hp_change": -5, "resource_desc": null, "threat_desc": "局部的小規模瓦斯爆炸、隨時發生的塌方。" },
  { "id": 2041, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E5%A4%B1%E9%80%9F%E6%9A%B4%E8%A1%9D%E7%9A%84%E5%88%97%E8%BB%8A.png?alt=media&token=1512cbc2-cad4-4f81-9476-0f7c97f486cc", "theme": "Train", "name": "失速暴衝的列車", "door_visual": "扭曲變形的車廂連接門，門上警告燈瘋狂閃爍。", "env_features": "強烈的車體震動與離心力，伴隨車輪與鐵軌激烈磨擦的刺耳尖叫。", "hp_change": -4, "resource_desc": null, "threat_desc": "車窗碎裂飛濺的鋼鐵碎片、上方行李架傾倒與高壓線路走火。" },
