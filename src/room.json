  { "id": 2043, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E8%90%AC%E4%B8%88%E9%AB%98%E6%A8%93%E9%8B%BC%E6%9E%B6.png?alt=media&token=64f444cc-2d22-48ab-9342-f24c3177ac0a", "theme": "Construction", "name": "萬丈高樓鋼架", "door_visual": "橘色鋼架構成的門，門後只有雲層與風聲。", "env_features": "強風不斷吹襲，沒有防護，必須在高空行走。", "hp_change": -5, "resource_desc": null, "threat_desc": "失足墜落的恐懼、飛來的建築廢料。" },
  { "id": 2044, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E9%9D%88%E9%AD%82%E8%BC%AA%E7%9B%A4%E8%B3%AD%E5%A0%B4.png?alt=media&token=fee6dc87-e966-4c7f-afc9-70cae8584fd9", "theme": "Casino", "name": "靈魂輪盤賭場", "door_visual": "金光閃閃的豪華門，門把手是輪盤造型。", "env_features": "空氣中充滿雪茄味，燈光誘人但帶有壓迫感。", "hp_change": -4, "resource_desc": null, "threat_desc": "自動發射的致命籌碼、奪取精力的賭博機台。" },
  { "id": 2045, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E6%B7%B1%E5%A4%9C%E7%9A%84%E7%94%9F%E7%89%A9%E6%95%99%E5%AE%A4.png?alt=media&token=ede79a40-83b3-485d-ab8b-aac26163ff72", "theme": "School", "name": "深夜的生物教室", "door_visual": "木門發出難聽的吱呀聲，門縫滲出酒精味。", "env_features": "福馬林中的標本似乎都在動，出現詭異生物影子。", "hp_change": -3, "resource_desc": null, "threat_desc": "自動解剖台的刀具、逃出瓶子的變異標本。" },
  { "id": 2046, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E6%95%85%E9%9A%9C%E7%9A%84%E5%82%B3%E9%80%81%E8%89%99.png?alt=media&token=2a29e498-61e7-4abd-adf9-48078bb681e5", "theme": "Futuristic", "name": "故障的傳送艙", "door_visual": "不斷閃爍藍白電弧的金屬艙門。", "env_features": "分子重組不完全，身體不斷感到撕裂般的痛。", "hp_change": -5, "resource_desc": null, "threat_desc": "肉體異化風險、電磁能量的持續灼傷。" },
  { "id": 2047, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E7%8B%82%E8%9C%82%E4%BE%B5%E8%A5%B2%E4%B9%8B%E5%9C%B0.png?alt=media&token=ad7ab4ea-d570-4c2f-a061-4ab43de07c15", "theme": "Nature", "name": "狂蜂侵襲之地", "door_visual": "蜂蠟封死的門，門後傳來萬千翅膀扇動聲。", "env_features": "空氣黏稠且熱，視線內全是密集的蜂巢結構。", "hp_change": -4, "resource_desc": null, "threat_desc": "無孔不入的劇毒蜂刺、過敏性休克威脅。" },
  { "id": 2048, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E5%86%B0%E9%8C%90%E8%90%AC%E5%8A%8D%E9%99%A3.png?alt=media&token=b61e9889-2b18-4f9d-8def-cb0b95c94785", "theme": "Ice", "name": "冰錐萬劍陣", "door_visual": "晶瑩剔透的冰門，內部封印著無數利刃。", "env_features": "地面極滑，天花板全是隨時落下的尖銳冰柱。", "hp_change": -5, "resource_desc": null, "threat_desc": "冰柱穿刺傷、極低溫凍傷、滑倒骨折。" },
  { "id": 2049, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E6%B7%B1%E6%B5%B7%E6%B4%A9%E5%A3%93%E8%A7%80%E6%99%AF%E8%89%99.png?alt=media&token=622a7079-871c-4f96-ab98-8d373d477525", "theme": "Underwater", "name": "深海洩壓觀景艙", "door_visual": "厚重的鋼鐵水密門，縫隙正不斷噴射出高壓水柱。", "env_features": "巨大水壓聲，冰冷的海水迅速漫過腳踝。", "hp_change": -6, "resource_desc": null, "threat_desc": "強化玻璃碎裂的預兆、鬆脫的重型儀器隨水流撞擊、漏電的控制面板。" },
  { "id": 2050, "type": "Asura", "imageUrl": "https://firebasestorage.googleapis.com/v0/b/image-hosting-9a719.firebasestorage.app/o/%E8%90%AC%E7%A5%9E%E6%AE%BF%E7%9A%84%E5%BB%A2%E5%A2%9F.png?alt=media&token=1d986029-c9ec-4d60-8d96-bb1b574b034d", "theme": "Abyss", "name": "萬神殿的廢墟", "door_visual": "崩塌的石拱門，門後只有無盡的灰燼。", "env_features": "信仰崩塌後的死寂，神力反噬導致肉體崩解。", "hp_change": -5, "resource_desc": null, "threat_desc": "殘留的毀滅性詛咒、不斷崩塌的石柱砸傷。" }
